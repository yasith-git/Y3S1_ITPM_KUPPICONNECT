PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB - Add your cluster URI here
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/kuppiconnect?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=KuppiConnect <your_email@gmail.com>
